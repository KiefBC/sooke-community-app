# Server
PORT=8080

# Database
DATABASE_URL=postgresql://<user>:<password>@<host>:<port>/<database>
TEST_DATABASE_URL=postgresql://<user>:<password>@<host>:<port>/<test_database>
MIGRATION_PATH=./server/migrations
TEST_MIGRATION_PATH=../../../server/migrations # Depends on where you run the tests from, adjust accordingly


# Goose
GOOSE_DRIVER=postgres
GOOSE_DBSTRING=same_as_DATABASE_URL
GOOSE_MIGRATION_DIR=./server/migrations
GOOSE_TABLE=goose_db_version
